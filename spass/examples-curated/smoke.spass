begin_problem(demo).

list_of_descriptions.
name().
author().
status(satisfiable).
description().
end_of_list.

list_of_symbols.
functions[plus,s,zero].
sorts[even,nat].
end_of_list.

list_of_declarations.
subsort(even,nat).
even(zero).
end_of_list.

list_of_formulae(axioms).
formula(forall([nat(y)],equal(plus(y,zero),y))).
end_of_list.

end_problem.
