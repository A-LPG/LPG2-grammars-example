begin_problem(Eq).

list_of_descriptions.
name().
author().
status(satisfiable).
description().
end_of_list.

list_of_symbols.
functions[f].
sorts[s].
end_of_list.

list_of_declarations.
forall([s(x),s(y)],equal(f(x),f(y))).
end_of_list.

list_of_formulae(axioms).
formula(forall([s(x)],equal(f(x),f(x)))).
end_of_list.

end_problem.
